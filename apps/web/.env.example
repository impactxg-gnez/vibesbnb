# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# In Supabase Dashboard → Authentication → Providers → Email: enable "Confirm email"
# so signups must click the verification link before they can use the app.

# App Configuration
# Canonical public URL (used for OAuth redirects — set to https://www.vibesbnb.com in production)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google OAuth (Supabase Dashboard setup — not env vars in this app)
# 1. Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client
#    - Authorized redirect URI: https://<project-ref>.supabase.co/auth/v1/callback
# 2. Supabase Dashboard → Authentication → Providers → Google → Enable + paste Client ID/Secret
# 3. Supabase Dashboard → Authentication → URL Configuration → Redirect URLs, add:
#    - http://localhost:3000/auth/callback
#    - https://www.vibesbnb.com/auth/callback
#    - https://vibesbnb.com/auth/callback

# Expo push (optional — mobile app registers tokens via /api/notifications/register-device)
# https://expo.dev/accounts/[account]/settings/access-tokens
EXPO_ACCESS_TOKEN=

# Email Configuration (Resend)
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx
# The from email must be verified in Resend dashboard
# For testing, you can use onboarding@resend.dev
RESEND_FROM_EMAIL=VibesBnB <noreply@yourdomain.com>

# Firebase Phone Auth (SMS OTP for /verify-phone — keeps Supabase as session source of truth)
# Firebase Console → Project settings → Your apps (Web) for public keys
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# Firebase Console → Project settings → Service accounts → Generate new private key
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# Enable Phone under Authentication → Sign-in method; add vibesbnb.com to Authorized domains.
# Disable Supabase Authentication → Providers → Phone (OTP no longer uses Supabase SMS).

# Google Maps (optional)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_key

# Stripe (optional - for payments)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxx
STRIPE_SECRET_KEY=sk_test_xxxx

# Upstash Redis (HTTP) — edge-safe cache + calendar priority queue
# https://console.upstash.com → create database → copy REST URL + token
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional: dedicated Bearer for POST /api/webhooks/calendar-sync (defaults to CRON_SECRET chain)
CALENDAR_SYNC_WEBHOOK_SECRET=

# PayPal (Live: https://api-m.paypal.com — Sandbox: https://api-m.sandbox.paypal.com)
NEXT_PUBLIC_PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_API_BASE=https://api-m.paypal.com
# From Developer Dashboard → your Live app → Webhooks (after you add the URL below)
PAYPAL_WEBHOOK_ID=
